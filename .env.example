# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/news_recommendation_db

# JWT (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Python Deep Learning service (DeepCARSKit) - for future integration
PYTHON_RECOMMENDER_URL=http://127.0.0.1:8000
PYTHON_RECOMMENDER_TIMEOUT_MS=10000
