# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/news_recommendation_db

# JWT (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Flask deep ranker (ml-service app.py)
PYTHON_RECOMMENDER_URL=http://localhost:5001
PYTHON_RECOMMENDER_TIMEOUT_MS=10000
